<Window x:Class="E3Studio.Dialogs.StockSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Stock Setup"
        Height="520" Width="480"
        Background="{StaticResource BgCardBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgCardBrush}" CornerRadius="12,12,0,0">
                <Grid>
                    <TextBlock Text="Stock Setup" 
                               Foreground="{StaticResource TextBrush}" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" 
                               Margin="16,0"/>
                    
                    <Button HorizontalAlignment="Right" Width="36" Height="36"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click" Cursor="Hand"
                            Background="Transparent" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                <Path x:Name="icon" Data="M8,8 L16,16 M16,8 L8,16" Stroke="{StaticResource TextMidBrush}" StrokeThickness="1.5"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                    <Setter TargetName="icon" Property="Stroke" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    
                    <!-- Stock Dimensions -->
                    <TextBlock Text="STOCK DIMENSIONS" Style="{StaticResource TextLabel}" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Width (X) -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Width (X)" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="2,0,0,4"/>
                            <Grid>
                                <TextBox x:Name="TxtWidth" Style="{StaticResource InputNumber}" Text="200"/>
                                <TextBlock Text="mm" Foreground="{StaticResource TextMutedBrush}" FontSize="10" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Height (Y) -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Height (Y)" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="2,0,0,4"/>
                            <Grid>
                                <TextBox x:Name="TxtHeight" Style="{StaticResource InputNumber}" Text="150"/>
                                <TextBlock Text="mm" Foreground="{StaticResource TextMutedBrush}" FontSize="10" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Thickness (Z) -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Thickness (Z)" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="2,0,0,4"/>
                            <Grid>
                                <TextBox x:Name="TxtThickness" Style="{StaticResource InputNumber}" Text="18"/>
                                <TextBlock Text="mm" Foreground="{StaticResource TextMutedBrush}" FontSize="10" 
                                          HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Zero Point -->
                    <TextBlock Text="ZERO POINT (ORIGIN)" Style="{StaticResource TextLabel}" Margin="0,8,0,12"/>
                    
                    <Border Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Origin Selection Grid -->
                            <Grid Grid.Column="0" Width="120" Height="90" HorizontalAlignment="Left">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Top Row -->
                                <RadioButton x:Name="OriginTL" Grid.Row="0" Grid.Column="0" GroupName="Origin" 
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Top Left"/>
                                <RadioButton x:Name="OriginTC" Grid.Row="0" Grid.Column="1" GroupName="Origin" IsChecked="True"
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Top Center"/>
                                <RadioButton x:Name="OriginTR" Grid.Row="0" Grid.Column="2" GroupName="Origin" 
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Top Right"/>
                                
                                <!-- Bottom Row -->
                                <RadioButton x:Name="OriginBL" Grid.Row="1" Grid.Column="0" GroupName="Origin" 
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Bottom Left"/>
                                <RadioButton x:Name="OriginBC" Grid.Row="1" Grid.Column="1" GroupName="Origin" 
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Bottom Center"/>
                                <RadioButton x:Name="OriginBR" Grid.Row="1" Grid.Column="2" GroupName="Origin" 
                                            Style="{StaticResource {x:Type ToggleButton}}" Content="◉" 
                                            Background="Transparent" BorderThickness="1" Margin="2"
                                            BorderBrush="{StaticResource BorderBrush}" ToolTip="Bottom Right"/>
                            </Grid>
                            
                            <!-- Preview -->
                            <Border Grid.Column="1" Width="140" Height="90" Background="{StaticResource BgDeepBrush}" 
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="4">
                                <Canvas x:Name="PreviewCanvas" ClipToBounds="True">
                                    <!-- Stock Preview Rectangle -->
                                    <Rectangle x:Name="PreviewStock" Width="100" Height="60" Canvas.Left="20" Canvas.Top="15"
                                              Stroke="{StaticResource AccentBrush}" StrokeThickness="1.5"
                                              Fill="#2000D4AA"/>
                                    <!-- Origin Point -->
                                    <Ellipse x:Name="PreviewOrigin" Width="8" Height="8" Canvas.Left="66" Canvas.Top="11"
                                            Fill="{StaticResource AccentWarningBrush}"/>
                                    <!-- Axes -->
                                    <Line x:Name="PreviewAxisX" X1="70" Y1="45" X2="90" Y2="45" 
                                          Stroke="#EF4444" StrokeThickness="1.5"/>
                                    <Line x:Name="PreviewAxisY" X1="70" Y1="45" X2="70" Y2="25" 
                                          Stroke="#10B981" StrokeThickness="1.5"/>
                                </Canvas>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Material Selection -->
                    <TextBlock Text="MATERIAL" Style="{StaticResource TextLabel}" Margin="0,8,0,12"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:Name="CmbMaterial" Grid.Column="0" SelectedIndex="0">
                            <ComboBoxItem Content="Hardwood (Oak, Maple)"/>
                            <ComboBoxItem Content="Softwood (Pine, Cedar)"/>
                            <ComboBoxItem Content="Plywood"/>
                            <ComboBoxItem Content="MDF"/>
                            <ComboBoxItem Content="Acrylic"/>
                            <ComboBoxItem Content="PVC/Foam"/>
                            <ComboBoxItem Content="Aluminum"/>
                            <ComboBoxItem Content="Custom..."/>
                        </ComboBox>
                        
                        <Button Grid.Column="1" Content="📚" Style="{StaticResource BtnGhost}" 
                                Width="36" Margin="8,0,0,0" ToolTip="Open Material Library"
                                Click="OpenMaterialLibrary_Click"/>
                    </Grid>
                    
                    <!-- Recommended Parameters (from material) -->
                    <Border Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="RECOMMENDED CUTTING PARAMETERS" Style="{StaticResource TextLabel}" 
                                      Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="Feed Rate" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtFeedRate" Text="800 mm/min" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="Plunge Rate" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtPlungeRate" Text="200 mm/min" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="Spindle RPM" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtSpindleRPM" Text="12000 RPM" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8">
                                    <TextBlock Text="Depth per Pass" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtDepthPerPass" Text="2.0 mm" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{StaticResource BgBaseBrush}" CornerRadius="0,0,12,12" Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource BtnSecondary}" 
                                Padding="20,8" Margin="0,0,8,0" Click="Cancel_Click"/>
                        <Button Content="Apply" Style="{StaticResource BtnPrimary}" 
                                Padding="20,8" Click="Apply_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
