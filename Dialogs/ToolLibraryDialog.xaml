<Window x:Class="E3Studio.Dialogs.ToolLibraryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tool Library"
        Height="620" Width="880"
        Background="{StaticResource BgCardBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgCardBrush}" CornerRadius="12,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Border Width="20" Height="20" CornerRadius="4" Background="{StaticResource AccentGradient}" Margin="0,0,8,0">
                            <Path Data="M12,2 L14,8 L10,8 Z M11,8 L11,18 M9,18 L13,18" 
                                  Stroke="#0D0D0F" StrokeThickness="1.2" Fill="Transparent" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Tool Library" 
                                   Foreground="{StaticResource TextBrush}" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — " Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Manage cutting tools" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Right" 
                            Width="36" Height="36"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click"
                            Cursor="Hand"
                            Background="Transparent" 
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                <Path x:Name="icon" Data="M8,8 L16,16 M16,8 L8,16" Stroke="{StaticResource TextMidBrush}" StrokeThickness="1.5"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                                    <Setter TargetName="icon" Property="Stroke" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Tool List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="TOOLS" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                    
                    <!-- Filter -->
                    <ComboBox x:Name="ToolTypeFilter" Grid.Row="1" Margin="0,0,0,8" SelectedIndex="0"
                              SelectionChanged="ToolTypeFilter_SelectionChanged">
                        <ComboBoxItem Content="All Tools"/>
                        <ComboBoxItem Content="Endmills"/>
                        <ComboBoxItem Content="Ball Nose"/>
                        <ComboBoxItem Content="V-Bits"/>
                        <ComboBoxItem Content="Drills"/>
                    </ComboBox>
                    
                    <Border Grid.Row="2" Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                        <ListBox x:Name="ToolList" 
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 SelectionChanged="ToolList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemModern}"/>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>
                    
                    <!-- List Actions -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Add" Style="{StaticResource BtnSecondary}" Padding="14,6" Margin="0,0,6,0" Click="AddTool_Click"/>
                        <Button Content="Duplicate" Style="{StaticResource BtnGhost}" Padding="10,6" Margin="0,0,6,0" Click="DuplicateTool_Click"/>
                        <Button Content="Delete" Style="{StaticResource BtnGhost}" Padding="10,6" Click="DeleteTool_Click" Foreground="{StaticResource AccentDangerBrush}"/>
                    </StackPanel>
                </Grid>
                
                <!-- Tool Details -->
                <Border Grid.Column="2" Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="TOOL DETAILS" Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>
                                
                                <!-- Name -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Tool Name" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtToolName" Style="{StaticResource InputText}"/>
                                </StackPanel>
                                
                                <!-- Type -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Tool Type" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ToolTypeCombo" SelectedIndex="0">
                                        <ComboBoxItem Content="Flat Endmill"/>
                                        <ComboBoxItem Content="Ball Nose"/>
                                        <ComboBoxItem Content="V-Bit"/>
                                        <ComboBoxItem Content="Drill"/>
                                        <ComboBoxItem Content="Engraver"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <!-- Dimensions -->
                                <TextBlock Text="DIMENSIONS" Style="{StaticResource TextLabel}" Margin="0,8,0,12"/>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Diameter (mm)" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtDiameter" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Flutes" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtFlutes" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Flute Length (mm)" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtFluteLength" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Total Length (mm)" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TxtTotalLength" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- V-Bit specific -->
                                <StackPanel x:Name="VAnglePanel" Margin="0,0,0,12" Visibility="Collapsed">
                                    <TextBlock Text="V-Angle (degrees)" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtVAngle" Style="{StaticResource InputNumber}" Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>
                                
                                <!-- Cutting Parameters -->
                                <TextBlock Text="CUTTING PARAMETERS" Style="{StaticResource TextLabel}" Margin="0,8,0,12"/>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Max Spindle RPM" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="18000" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Max Feed (mm/min)" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="1500" Style="{StaticResource InputNumber}"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Material Compatibility -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Recommended Materials" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                            <TextBlock Text="Wood" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                            <TextBlock Text="Plastic" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                            <TextBlock Text="Aluminum" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                
                                <!-- Notes -->
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Notes" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtNotes" Style="{StaticResource InputText}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <!-- Tool Preview -->
                        <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" CornerRadius="6" Margin="16,0,0,0">
                            <Grid>
                                <Canvas x:Name="PreviewCanvas" Width="80" Height="160" Margin="0,10,0,0"/>
                                
                                <TextBlock Text="Tool Preview" Foreground="{StaticResource TextMutedBrush}" FontSize="9" 
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Footer Buttons -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
                <Grid Margin="16,0">
                    <Button Content="Import Tools..." Style="{StaticResource BtnGhost}" HorizontalAlignment="Left" VerticalAlignment="Center" Click="ImportTools_Click"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Apply" Style="{StaticResource BtnPrimary}" Width="100" Margin="0,0,8,0" Click="Apply_Click"/>
                        <Button Content="Close" Style="{StaticResource BtnSecondary}" Width="100" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
