<Window x:Class="E3Studio.Dialogs.GridSnapSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grid &amp; Snap Settings" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#DCDCDC"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Grid Settings -->
        <GroupBox Grid.Row="0" Header="Grid Display">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox x:Name="ChkShowGrid" Content="Show grid" Grid.ColumnSpan="2"
                          IsChecked="True"/>
                
                <TextBlock Grid.Row="1" Text="Grid spacing:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="TxtGridSpacing" Text="10" Width="60"/>
                    <TextBlock Text="mm" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Grid.Row="2" Text="Major lines every:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBox x:Name="TxtMajorLines" Text="5" Width="60"/>
                    <TextBlock Text="lines" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Grid.Row="3" Text="Grid color:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="GridColorCombo" Margin="0,8,0,0">
                    <ComboBoxItem Content="Light Gray" Tag="#404040" IsSelected="True"/>
                    <ComboBoxItem Content="Dark Gray" Tag="#2A2A2A"/>
                    <ComboBoxItem Content="Blue" Tag="#1A3A5C"/>
                    <ComboBoxItem Content="Green" Tag="#1A3A1A"/>
                </ComboBox>
            </Grid>
        </GroupBox>
        
        <!-- Snap Settings -->
        <GroupBox Grid.Row="1" Header="Snap Options">
            <StackPanel>
                <CheckBox x:Name="ChkSnapToGrid" Content="Snap to grid (G)" IsChecked="True"/>
                <CheckBox x:Name="ChkSnapToEndpoint" Content="Snap to endpoint (E)" IsChecked="True"/>
                <CheckBox x:Name="ChkSnapToMidpoint" Content="Snap to midpoint (M)" IsChecked="True"/>
                <CheckBox x:Name="ChkSnapToCenter" Content="Snap to center (C)" IsChecked="True"/>
                <CheckBox x:Name="ChkSnapToIntersection" Content="Snap to intersection (I)" IsChecked="True"/>
                <CheckBox x:Name="ChkSnapToPerpendicular" Content="Snap to perpendicular (P)"/>
                <CheckBox x:Name="ChkSnapToTangent" Content="Snap to tangent (T)"/>
                <CheckBox x:Name="ChkSnapToNearest" Content="Snap to nearest (N)"/>
                
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Snap radius:" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox x:Name="TxtSnapRadius" Text="10" Width="60"/>
                        <TextBlock Text="pixels" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </GroupBox>
        
        <!-- Angle Constraints -->
        <GroupBox Grid.Row="2" Header="Angle Constraints">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox x:Name="ChkOrthoMode" Content="Ortho mode (F8)" Grid.ColumnSpan="2" IsChecked="False"/>
                
                <TextBlock Grid.Row="1" Text="Polar angle:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <ComboBox x:Name="PolarAngleCombo" Width="80">
                        <ComboBoxItem Content="15°" Tag="15"/>
                        <ComboBoxItem Content="30°" Tag="30"/>
                        <ComboBoxItem Content="45°" Tag="45" IsSelected="True"/>
                        <ComboBoxItem Content="90°" Tag="90"/>
                    </ComboBox>
                    <CheckBox x:Name="ChkPolarTracking" Content="Polar tracking (F10)" 
                              Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Reset Defaults" Padding="15,8" Margin="0,0,10,0"
                    Background="#3C3C3C" Foreground="White" BorderThickness="0"
                    Click="ResetDefaults_Click"/>
            <Button Content="OK" Padding="20,8" Margin="0,0,10,0"
                    Background="#0E639C" Foreground="White" BorderThickness="0"
                    Click="OK_Click"/>
            <Button Content="Cancel" Padding="20,8"
                    Background="#3C3C3C" Foreground="White" BorderThickness="0"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
