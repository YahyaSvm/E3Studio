<Window x:Class="E3Studio.Dialogs.GCodeExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export G-Code" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#DCDCDC"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Post-Processor Selection -->
        <GroupBox Grid.Row="0" Header="Post-Processor">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Controller:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="PostProcessorCombo" 
                          SelectionChanged="PostProcessorCombo_SelectionChanged">
                    <ComboBoxItem Content="Generic (Fanuc-style)" Tag="Generic"/>
                    <ComboBoxItem Content="GRBL 1.1" Tag="Grbl" IsSelected="True"/>
                    <ComboBoxItem Content="Mach3" Tag="Mach3"/>
                    <ComboBoxItem Content="Mach4" Tag="Mach4"/>
                    <ComboBoxItem Content="LinuxCNC" Tag="LinuxCNC"/>
                    <ComboBoxItem Content="Fanuc" Tag="Fanuc"/>
                    <ComboBoxItem Content="HAAS" Tag="Haas"/>
                    <ComboBoxItem Content="Mazak" Tag="Mazak"/>
                </ComboBox>
                
                <TextBlock Grid.Row="1" Text="Description:" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PostDescription" 
                           Text="GRBL 1.1 compatible post-processor" 
                           TextWrapping="Wrap" Foreground="#888888"
                           Margin="0,10,0,0"/>
            </Grid>
        </GroupBox>
        
        <!-- Output File -->
        <GroupBox Grid.Row="1" Header="Output File">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="OutputPath" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="Browse..." Margin="10,0,0,0"
                        Padding="15,6" Background="#3C3C3C" Foreground="White"
                        BorderThickness="0" Click="BrowseOutput_Click"/>
            </Grid>
        </GroupBox>
        
        <!-- G-Code Options -->
        <GroupBox Grid.Row="2" Header="G-Code Options">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <CheckBox x:Name="ChkLineNumbers" Content="Include line numbers"/>
                    <CheckBox x:Name="ChkComments" Content="Include comments" IsChecked="True"/>
                    <CheckBox x:Name="ChkToolChangePause" Content="Pause on tool change" IsChecked="True"/>
                    <CheckBox x:Name="ChkSpindleDelay" Content="Spindle delay after M3"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <CheckBox x:Name="ChkArcOutput" Content="Use arc commands (G2/G3)" IsChecked="True"/>
                    <CheckBox x:Name="ChkAbsoluteIJ" Content="Absolute I/J (arc center)"/>
                    <CheckBox x:Name="ChkModalGroups" Content="Modal G-codes" IsChecked="True"/>
                    <CheckBox x:Name="ChkOptimizeRapids" Content="Optimize rapid moves"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- Units and Format -->
        <GroupBox Grid.Row="3" Header="Units &amp; Format">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Units:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="UnitsCombo" Margin="0,0,15,0">
                    <ComboBoxItem Content="Metric (mm)" IsSelected="True"/>
                    <ComboBoxItem Content="Imperial (inch)"/>
                </ComboBox>
                
                <TextBlock Grid.Column="2" Text="Precision:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="3" x:Name="PrecisionCombo">
                    <ComboBoxItem Content="2 decimals"/>
                    <ComboBoxItem Content="3 decimals" IsSelected="True"/>
                    <ComboBoxItem Content="4 decimals"/>
                </ComboBox>
                
                <TextBlock Grid.Row="1" Text="Line ending:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LineEndingCombo" Margin="0,10,15,0">
                    <ComboBoxItem Content="Windows (CRLF)" IsSelected="True"/>
                    <ComboBoxItem Content="Unix (LF)"/>
                </ComboBox>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Text="File extension:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="FileExtension" Text=".nc" Margin="0,10,0,0"/>
                
                <TextBlock Grid.Row="2" Text="Safe height:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10,15,0">
                    <TextBox x:Name="SafeHeight" Text="5.0" Width="60"/>
                    <TextBlock Text="mm" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <!-- Preview -->
        <GroupBox Grid.Row="4" Header="Preview">
            <TextBox x:Name="GCodePreview" IsReadOnly="True"
                     Background="#252526" FontFamily="Consolas" FontSize="11"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" AcceptsReturn="True"/>
        </GroupBox>
        
        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Content="Preview" Padding="15,8"
                    Background="#3C3C3C" Foreground="White" BorderThickness="0"
                    Click="Preview_Click"/>
            
            <Button Grid.Column="2" Content="Export" Padding="20,8" Margin="0,0,10,0"
                    Background="#0E639C" Foreground="White" BorderThickness="0"
                    Click="Export_Click"/>
            
            <Button Grid.Column="3" Content="Cancel" Padding="20,8"
                    Background="#3C3C3C" Foreground="White" BorderThickness="0"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
