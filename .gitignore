# ==============================================================================
# E3Studio .gitignore
# Comprehensive ignore rules for C++/C#/React/Node.js cross-platform project
# ==============================================================================

# ─── Build Output ─────────────────────────────────────────────────────────────
build/
out/
dist/
bin/
obj/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj
*.pdb
*.ilk
*.exp

# ─── CMake ────────────────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake
install_manifest.txt

# ─── vcpkg ────────────────────────────────────────────────────────────────────
vcpkg/
vcpkg_installed/
vcpkg-manifest-install.log
*.nuget.*

# ─── .NET / C# / WPF ─────────────────────────────────────────────────────────
*.csproj.user
*.suo
*.user
*.sln.docstates
.vs/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
TestResults/
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.mdf
*.ldf
packages/
*.DotSettings.user

# ─── Node.js / React / UI ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json

# Visual Studio
.idea/
*.sln.iml

# JetBrains
.idea/
*.iml

# CLion / CMake IDE
.claude/
.ccache/

# Qt Creator
*.pro.user
*.pro.user.*

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Other editors
*~
*.swp
*.swo
\#*\#
.\#*
*.sublime-workspace
*.sublime-project
*.code-workspace

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
error_log.txt
stdout.txt
stderr.txt
npm-debug.log
yarn-debug.log
yarn-error.log

# ─── Temporary Files ──────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
.cache/
.parcel-cache/
.vite/

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
*.pfx
*.p12

# ─── Test / Coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
htmlcov/
.coverage
.coverage.*

# ─── Documentation ────────────────────────────────────────────────────────────
docs/_build/
docs/.doctrees/

# ─── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.map
*.min.js
*.min.css
__pycache__/
*.pyc
*.pyo
