<UserControl x:Class="E3Studio.Controls.LayerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#252526" Foreground="#DCDCDC">
    
    <UserControl.Resources>
        <Style x:Key="LayerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="Transparent" 
                                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="VisibilityToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="border" Width="20" Height="20" 
                                Background="Transparent" CornerRadius="2"
                                Cursor="Hand">
                            <Path x:Name="icon" Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                  Fill="#AAAAAA" Stretch="Uniform" Width="14" Height="14"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="icon" Property="Data" 
                                        Value="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"/>
                                <Setter TargetName="icon" Property="Fill" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="LockToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="border" Width="20" Height="20" 
                                Background="Transparent" CornerRadius="2"
                                Cursor="Hand">
                            <Path x:Name="icon" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                  Fill="#666666" Stretch="Uniform" Width="12" Height="12"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="icon" Property="Fill" Value="#FF9800"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Background="#2D2D30" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Layers" FontWeight="SemiBold" FontSize="13"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnAddLayer" Content="+" Width="24" Height="24"
                            Background="#3C3C3C" Foreground="White" BorderThickness="0"
                            FontWeight="Bold" Margin="0,0,4,0" Click="BtnAddLayer_Click"
                            ToolTip="Add new layer"/>
                    <Button x:Name="BtnDeleteLayer" Content="−" Width="24" Height="24"
                            Background="#3C3C3C" Foreground="White" BorderThickness="0"
                            FontWeight="Bold" Click="BtnDeleteLayer_Click"
                            ToolTip="Delete selected layer"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Layer List -->
        <ListBox Grid.Row="1" x:Name="LayerList" 
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource LayerItemStyle}"
                 SelectionChanged="LayerList_SelectionChanged"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="LayerList_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="LayerList_PreviewMouseMove"
                 Drop="LayerList_Drop">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Visibility toggle -->
                        <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                  Style="{StaticResource VisibilityToggle}"
                                  Click="Visibility_Click"/>
                        
                        <!-- Lock toggle -->
                        <CheckBox Grid.Column="1" IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                  Style="{StaticResource LockToggle}"
                                  Click="Lock_Click"/>
                        
                        <!-- Color indicator -->
                        <Rectangle Grid.Column="2" Width="16" Height="16" 
                                   Margin="6,0" RadiusX="2" RadiusY="2">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="{Binding Color}"/>
                            </Rectangle.Fill>
                            <Rectangle.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Red" Tag="#FF5252" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Green" Tag="#4CAF50" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Blue" Tag="#2196F3" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Yellow" Tag="#FFEB3B" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Orange" Tag="#FF9800" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Purple" Tag="#9C27B0" Click="ColorMenu_Click"/>
                                    <MenuItem Header="Cyan" Tag="#00BCD4" Click="ColorMenu_Click"/>
                                    <MenuItem Header="White" Tag="#FFFFFF" Click="ColorMenu_Click"/>
                                </ContextMenu>
                            </Rectangle.ContextMenu>
                        </Rectangle>
                        
                        <!-- Layer name -->
                        <TextBlock Grid.Column="3" Text="{Binding Name}" 
                                   VerticalAlignment="Center"
                                   Foreground="{Binding IsVisible, Converter={StaticResource VisibilityToForegroundConverter}}"/>
                        
                        <!-- Object count -->
                        <TextBlock Grid.Column="4" Text="{Binding ObjectCount, StringFormat='({0})'}"
                                   Foreground="#888888" VerticalAlignment="Center"
                                   FontSize="11" Margin="8,0"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Footer actions -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Show All" Padding="8,4" Margin="0,0,8,0"
                        Background="#3C3C3C" Foreground="White" BorderThickness="0"
                        Click="ShowAll_Click"/>
                <Button Content="Hide All" Padding="8,4" Margin="0,0,8,0"
                        Background="#3C3C3C" Foreground="White" BorderThickness="0"
                        Click="HideAll_Click"/>
                <Button Content="Merge" Padding="8,4"
                        Background="#3C3C3C" Foreground="White" BorderThickness="0"
                        Click="Merge_Click" ToolTip="Merge selected layers"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
