                                <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,36,0,16"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="3" Padding="6,3" Margin="0,0,4,0">
                                        <TextBlock Text="Ctrl+N" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                    </Border>
                                    <TextBlock Text=" New" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="3" Padding="6,3" Margin="0,0,4,0">
                                        <TextBlock Text="Ctrl+O" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                    </Border>
                                    <TextBlock Text=" Open" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <Border Background="{StaticResource BgCardBrush}" CornerRadius="3" Padding="6,3" Margin="0,0,4,0">
                                        <TextBlock Text="Ctrl+S" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                    </Border>
                                    <TextBlock Text=" Save" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    
                    <avalonDock:DockingManager x:Name="DockManager" Background="{StaticResource BgDeepBrush}" DocumentHeaderTemplate="{x:Null}">
                        <avalonDock:DockingManager.Theme>
                            <avalonDock:Vs2013DarkTheme/>
                        </avalonDock:DockingManager.Theme>
                        
                        <avalonDock:LayoutRoot>
                            <avalonDock:LayoutPanel Orientation="Horizontal">
                                <!-- Left Panel: Explorer -->
                                <avalonDock:LayoutAnchorablePaneGroup DockWidth="280">
                                    <avalonDock:LayoutAnchorablePane>
                                        <avalonDock:LayoutAnchorable Title="Explorer" CanClose="False" CanHide="False" CanFloat="True">
                                            <Border Background="{StaticResource BgCardBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <Border Grid.Row="0" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="+ Setup" Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="10" Margin="0,0,4,0"/>
                                                            <Button Content="+ Folder" Style="{StaticResource BtnGhost}" Padding="8,4" FontSize="10"/>
                                                        </StackPanel>
                                                    </Border>
                                                    
                                                    <TextBox Grid.Row="1" Margin="10" Style="{StaticResource InputText}" Tag="Search..." Text=""/>
                                                    
                                                    <TreeView Grid.Row="2" x:Name="ProjectTree" Background="Transparent" BorderThickness="0" Margin="4" 
                                                              SelectedItemChanged="ProjectTree_SelectedItemChanged">
                                                        <TreeView.Resources>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:ProjectRootNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Fill="{StaticResource AccentBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:WCSNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenu="{StaticResource NodeContextMenu}">
                                                                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z" Fill="{StaticResource AccentWarningBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:FolderNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenu="{StaticResource NodeContextMenu}">
                                                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{StaticResource AccentSecondaryBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:LayerNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenu="{StaticResource NodeContextMenu}">
                                                                    <Path Data="M12,16L19.36,10.27L21,9L12,2L3,9L4.63,10.27M12,18.54L4.62,12.81L3,14.07L12,21.07L21,14.07L19.37,12.8L12,18.54Z" Fill="{StaticResource AccentBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:GeometryNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenu="{StaticResource NodeContextMenu}">
                                                                    <Path Data="M18.6,10c-1.3-4.5-5.3-7.6-10-7.1C5.1,3.2,2.3,6.2,2,9.9c3,0,13.5,0,16.6,0.1" Stroke="{StaticResource TextBrush}" StrokeThickness="1" Width="12" Height="12" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" FontSize="11"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:GroupNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenu="{StaticResource NodeContextMenu}">
                                                                    <Path Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2.01,6L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16V18z" Fill="{StaticResource AccentSecondaryBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text=" (Group)" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="4,0,0,0"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                            <HierarchicalDataTemplate DataType="{x:Type local:ToolpathNode}">
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <Path Data="M4,4 L20,4 L20,20 L4,20 Z" Stroke="{StaticResource AccentWarningBrush}" StrokeThickness="1.5" Width="12" Height="12" Margin="1,0,7,0"/>
                                                                    <TextBlock Text="{Binding Data.Name}"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                        </TreeView.Resources>
                                                        <TreeView.ItemContainerStyle>
                                                            <Style TargetType="TreeViewItem">
                                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                                <Setter Property="Padding" Value="4,2"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="TreeViewItem">
                                                                            <Grid>
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                    <RowDefinition Height="*"/>
                                                                                </Grid.RowDefinitions>
                                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="2">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="16"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <ToggleButton x:Name="Expander" Style="{StaticResource {x:Type ToggleButton}}" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Content="▼" Foreground="{StaticResource TextSecondaryBrush}" FontSize="8" Background="Transparent" BorderThickness="0" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        <ContentPresenter Grid.Column="1" x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                                <ItemsPresenter Grid.Row="1" x:Name="ItemsHost" Margin="16,0,0,0"/>
                                                                            </Grid>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsExpanded" Value="false">
                                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsSelected" Value="true">
                                                                                    <Setter TargetName="Bd" Property="Background" Value="#2D2D38"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                                </Trigger>
                                                                                <Trigger Property="HasItems" Value="false">
                                                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </TreeView.ItemContainerStyle>
                                                    </TreeView>
                                                </Grid>
                                            </Border>
                                        </avalonDock:LayoutAnchorable>
                                        
                                        <avalonDock:LayoutAnchorable Title="Tool Library" CanClose="False" CanHide="True" CanFloat="True">
                                            <Border Background="{StaticResource BgCardBrush}" Padding="12">
                                                <StackPanel>
                                                    <TextBlock Text="TOOL LIBRARY" Style="{StaticResource TextLabel}" Margin="0,0,0,10"/>
                                                    <Button Content="Manage Tools" Style="{StaticResource BtnGhost}" HorizontalAlignment="Stretch" Click="OpenToolLibrary_Click"/>
                                                    <Button Content="Post Processors" Style="{StaticResource BtnGhost}" HorizontalAlignment="Stretch" Click="OpenPostProcessorManager_Click"/>
                                                    <Button Content="Materials" Style="{StaticResource BtnGhost}" HorizontalAlignment="Stretch" Click="OpenMaterialLibrary_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </avalonDock:LayoutAnchorable>
                                    </avalonDock:LayoutAnchorablePane>
                                </avalonDock:LayoutAnchorablePaneGroup>
                                
                                <!-- Center: Viewport -->
                                <avalonDock:LayoutDocumentPaneGroup>
                                    <avalonDock:LayoutDocumentPane>
                                        <avalonDock:LayoutDocument Title="Viewport" CanClose="False">
                                            <Grid Background="{StaticResource BgDeepBrush}">
                                                <!-- 2D View -->
                                                <Border x:Name="View2D" Background="#0A0A0C" Visibility="Visible">
                                                    <Grid>
                                                        <Canvas x:Name="MainCanvas" Background="Transparent" ClipToBounds="True"
                                                                MouseWheel="Canvas_MouseWheel" MouseDown="Canvas_MouseDown" 
                                                                MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp"/>
                                                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12" Padding="8,4" Background="#CC141419" CornerRadius="4">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="2D VIEW" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                                                <TextBlock Text="Zoom:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                                <TextBlock x:Name="ZoomLevel" Text=" 100%" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="12" Padding="8,4" Background="#CC141419" CornerRadius="4">
                                                            <TextBlock x:Name="CursorPos" Text="X: 0.000  Y: 0.000" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                                        </Border>
                                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12" Width="60" Height="60" Background="#CC141419" CornerRadius="4">
                                                            <Canvas>
                                                                <Line X1="30" Y1="40" X2="55" Y2="40" Stroke="#EF4444" StrokeThickness="2"/>
                                                                <Line X1="30" Y1="40" X2="30" Y2="15" Stroke="#10B981" StrokeThickness="2"/>
                                                                <TextBlock Text="X" Canvas.Left="50" Canvas.Top="28" Foreground="#EF4444" FontSize="9"/>
                                                                <TextBlock Text="Y" Canvas.Left="23" Canvas.Top="8" Foreground="#10B981" FontSize="9"/>
                                                            </Canvas>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                
                                                <!-- 3D View -->
                                                <Border x:Name="View3D" Background="#0A0A0C" Visibility="Collapsed">
                                                    <Grid>
                                                        <helix:HelixViewport3D x:Name="Viewport3D" ShowCoordinateSystem="True" CoordinateSystemLabelForeground="Gray" Background="#0A0A0C" ZoomExtentsWhenLoaded="True" ShowViewCube="True" ViewCubeBackText="Back" ViewCubeFrontText="Front" ViewCubeLeftText="Left" ViewCubeRightText="Right" ViewCubeTopText="Top" ViewCubeBottomText="Bottom">
                                                            <helix:DefaultLights/>
                                                            <helix:GridLinesVisual3D x:Name="Grid3D" Width="400" Length="400" MinorDistance="10" MajorDistance="50" Thickness="0.05" Fill="#1A1A1A"/>
                                                            <helix:BoxVisual3D x:Name="StockBox3D" Center="100,75,9" Width="200" Length="150" Height="18" Fill="#3000D4AA"/>
                                                            <helix:TruncatedConeVisual3D x:Name="ToolVisual3D" Origin="0,0,50" Height="25" BaseRadius="3" TopRadius="3" Fill="#CCAAAACC"/>
                                                            <ModelVisual3D x:Name="ToolpathVisual3D"/>
                                                            <ModelVisual3D x:Name="CutSimulationVisual3D"/>
                                                        </helix:HelixViewport3D>
                                                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12" Padding="10,8" Background="#E0141419" CornerRadius="6">
                                                            <StackPanel>
                                                                <TextBlock Text="3D PREVIEW" Foreground="{StaticResource AccentSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Tool: " Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                                    <TextBlock x:Name="ToolInfo3D" Text="Ø6mm EndMill" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Position: " Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                                    <TextBlock x:Name="ToolPosition3D" Text="X:0.00 Y:0.00 Z:0.00" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="12" Padding="12,8" Background="#E0141419" CornerRadius="6">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,8">
                                                                    <ProgressBar x:Name="SimulationProgress" Height="4" Minimum="0" Maximum="100" Value="0" Background="#333" Foreground="#00D4AA"/>
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                    <Button x:Name="BtnSimRewind" Style="{StaticResource BtnIcon}" Width="32" Height="32" Click="SimRewind_Click" ToolTip="Rewind">
                                                                        <Path Data="M12,5 L4,12 L12,19 M20,5 L12,12 L20,19" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                                                                    </Button>
                                                                    <Button x:Name="BtnSimStepBack" Style="{StaticResource BtnIcon}" Width="32" Height="32" Click="SimStepBack_Click" ToolTip="Step Back">
                                                                        <Path Data="M15,5 L7,12 L15,19" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                                                                    </Button>
                                                                    <Button x:Name="BtnSimPlay" Style="{StaticResource BtnIcon}" Width="40" Height="40" Click="SimPlay_Click" ToolTip="Play/Pause">
                                                                        <Path x:Name="PlayPauseIcon" Data="M8,5 L8,19 L19,12 Z" Fill="#00D4AA"/>
                                                                    </Button>
                                                                    <Button x:Name="BtnSimStepFwd" Style="{StaticResource BtnIcon}" Width="32" Height="32" Click="SimStepForward_Click" ToolTip="Step Forward">
                                                                        <Path Data="M9,5 L17,12 L9,19" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                                                                    </Button>
                                                                    <Button x:Name="BtnSimStop" Style="{StaticResource BtnIcon}" Width="32" Height="32" Click="SimStop_Click" ToolTip="Stop">
                                                                        <Path Data="M6,6 L18,6 L18,18 L6,18 Z" Fill="{StaticResource TextSecondaryBrush}"/>
                                                                    </Button>
                                                                    <Border Width="1" Background="#444" Margin="8,4"/>
                                                                    <TextBlock Text="Speed:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                                                                    <ComboBox x:Name="SimSpeedCombo" Width="60" Height="24" SelectionChanged="SimSpeed_Changed" Background="#222" Foreground="White" FontSize="10">
                                                                        <ComboBoxItem Content="0.25x" Tag="0.25"/>
                                                                        <ComboBoxItem Content="0.5x" Tag="0.5"/>
                                                                        <ComboBoxItem Content="1x" Tag="1" IsSelected="True"/>
                                                                        <ComboBoxItem Content="2x" Tag="2"/>
                                                                        <ComboBoxItem Content="5x" Tag="5"/>
                                                                        <ComboBoxItem Content="10x" Tag="10"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                                                    <TextBlock x:Name="SimMoveInfo" Text="Move: 0 / 0" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                                    <TextBlock Text=" | " Foreground="#444"/>
                                                                    <TextBlock x:Name="SimMoveType" Text="Ready" Foreground="#00D4AA" FontSize="10"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="12" Padding="6" Background="#E0141419" CornerRadius="6">
                                                            <StackPanel>
                                                                <Button Style="{StaticResource BtnIcon}" Width="28" Height="28" Click="View3D_Top_Click" ToolTip="Top View">
                                                                    <TextBlock Text="T" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                                                                </Button>
                                                                <Button Style="{StaticResource BtnIcon}" Width="28" Height="28" Click="View3D_Front_Click" ToolTip="Front View">
                                                                    <TextBlock Text="F" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                                                                </Button>
                                                                <Button Style="{StaticResource BtnIcon}" Width="28" Height="28" Click="View3D_Side_Click" ToolTip="Side View">
                                                                    <TextBlock Text="S" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                                                                </Button>
                                                                <Button Style="{StaticResource BtnIcon}" Width="28" Height="28" Click="View3D_Iso_Click" ToolTip="Isometric View">
                                                                    <TextBlock Text="I" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                                                                </Button>
                                                                <Border Height="1" Background="#444" Margin="2,4"/>
                                                                <Button Style="{StaticResource BtnIcon}" Width="28" Height="28" Click="View3D_ZoomFit_Click" ToolTip="Zoom to Fit">
                                                                    <Path Data="M3,3 L10,3 M3,3 L3,10 M21,3 L14,3 M21,3 L21,10 M3,21 L10,21 M3,21 L3,14 M21,21 L14,21 M21,21 L21,14" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12,0,12,70" Padding="8,6" Background="#E0141419" CornerRadius="4">
                                                            <StackPanel>
                                                                <TextBlock Text="LEGEND" Foreground="{StaticResource TextTertiaryBrush}" FontSize="9" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <Border Width="12" Height="3" Background="#FF6464" CornerRadius="1"/>
                                                                    <TextBlock Text=" Rapid" Foreground="{StaticResource TextTertiaryBrush}" FontSize="9"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <Border Width="12" Height="3" Background="#00D4AA" CornerRadius="1"/>
                                                                    <TextBlock Text=" Feed" Foreground="{StaticResource TextTertiaryBrush}" FontSize="9"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <Border Width="12" Height="3" Background="#FFC832" CornerRadius="1"/>
                                                                    <TextBlock Text=" Plunge" Foreground="{StaticResource TextTertiaryBrush}" FontSize="9"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </avalonDock:LayoutDocument>
                                    </avalonDock:LayoutDocumentPane>
                                </avalonDock:LayoutDocumentPaneGroup>
                                
                                <!-- Right Panel: Properties -->
                                <avalonDock:LayoutAnchorablePaneGroup DockWidth="300">
                                    <avalonDock:LayoutAnchorablePane>
                                        <avalonDock:LayoutAnchorable Title="Properties" CanClose="False" CanHide="False" CanFloat="True">
                                            <Border Background="{StaticResource BgCardBrush}" Padding="12">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="PropertiesPanel">
                                                        <Grid x:Name="TransformProperties" Visibility="Collapsed">
                                                            <StackPanel>
                                                                <Border Background="{StaticResource BgElevatedBrush}" Padding="10,6" CornerRadius="4" Margin="0,0,0,6">
                                                                    <TextBlock Text="TRANSFORM" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <TextBlock Text="Position (mm)" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                                                <Grid Margin="0,0,0,12">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="6"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="X" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="2,0,0,2"/>
                                                                        <TextBox x:Name="PropPosX" Style="{StaticResource InputNumber}" Tag="X"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2">
                                                                        <TextBlock Text="Y" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="2,0,0,2"/>
                                                                        <TextBox x:Name="PropPosY" Style="{StaticResource InputNumber}" Tag="Y"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <TextBlock Text="Scale" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                                                <Grid Margin="0,0,0,12">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="6"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="X" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="2,0,0,2"/>
                                                                        <TextBox x:Name="PropScaleX" Style="{StaticResource InputNumber}" Tag="SX"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2">
                                                                        <TextBlock Text="Y" Foreground="{StaticResource TextMutedBrush}" FontSize="9" Margin="2,0,0,2"/>
                                                                        <TextBox x:Name="PropScaleY" Style="{StaticResource InputNumber}" Tag="SY"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <TextBlock Text="Rotation (°)" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                                                <Grid Margin="0,0,0,12">
                                                                    <TextBox x:Name="PropRotation" Style="{StaticResource InputNumber}" Tag="R"/>
                                                                </Grid>
                                                                <Button Content="Apply Transform" Style="{StaticResource BtnPrimary}" Margin="0,8,0,0" x:Name="BtnApplyTransform" Click="BtnApplyTransform_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid x:Name="PathInfoSection" Visibility="Collapsed">
                                                            <StackPanel>
                                                                <Border Background="{StaticResource BgElevatedBrush}" Padding="10,6" CornerRadius="4" Margin="0,12,0,8">
                                                                    <TextBlock Text="PATH INFO" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="SEGMENTS" Style="{StaticResource TextLabel}" Margin="0,0,0,2"/>
                                                                        <TextBlock x:Name="PropSegments" Text="—" FontFamily="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="CLOSED" Style="{StaticResource TextLabel}" Margin="0,0,0,2"/>
                                                                        <TextBlock x:Name="PropClosed" Text="—" FontFamily="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <Grid Margin="0,8,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="WIDTH (mm)" Style="{StaticResource TextLabel}" Margin="0,0,0,2"/>
                                                                        <TextBlock x:Name="PropBoundsW" Text="—" FontFamily="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="HEIGHT (mm)" Style="{StaticResource TextLabel}" Margin="0,0,0,2"/>
                                                                        <TextBlock x:Name="PropBoundsH" Text="—" FontFamily="{StaticResource MonoFont}" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <Border Background="{StaticResource BgElevatedBrush}" Padding="10,6" CornerRadius="4" Margin="0,12,0,8">
                                                                    <TextBlock Text="APPEARANCE" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border x:Name="ColorPreview" Width="24" Height="24" CornerRadius="4" Background="{StaticResource AccentBrush}" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonUp="ColorPreview_Click" ToolTip="Click to change color"/>
                                                                    <TextBox x:Name="PropColor" Style="{StaticResource InputText}" Width="90" Tag="#RRGGBB" LostFocus="PropColor_LostFocus"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid x:Name="NoSelectionProperties">
                                                            <StackPanel>
                                                                <TextBlock Text="No Object Selected" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,40,0,8"/>
                                                                <TextBlock Text="Select an object in the viewport to view and edit its properties" Foreground="{StaticResource TextMutedBrush}" FontSize="10" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </avalonDock:LayoutAnchorable>
                                        <avalonDock:LayoutAnchorable Title="G-Code" CanClose="False" CanHide="True" CanFloat="True">
                                            <Border Background="{StaticResource BgCardBrush}" Padding="12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="G-CODE PREVIEW" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                                    <Border Grid.Row="1" Background="{StaticResource BgDeepBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                        <TextBox x:Name="GCodePreview" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource MonoFont}" FontSize="10" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0" Padding="8" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Text="; E3Studio G-Code&#x0a;; Generated: 2024-12-30&#x0a;&#x0a;G21 ; mm&#x0a;G90 ; Absolute&#x0a;G17 ; XY Plane&#x0a;&#x0a;; Toolpath preview..."/>
                                                    </Border>
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Button Content="Export G-Code" Style="{StaticResource BtnSecondary}" Padding="12,6" Margin="0,0,6,0" Click="GCodePanel_Export_Click"/>
                                                        <Button Content="Copy to Clipboard" Style="{StaticResource BtnGhost}" Padding="12,6" Click="GCodePanel_Copy_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </avalonDock:LayoutAnchorable>
                                    </avalonDock:LayoutAnchorablePane>
                                </avalonDock:LayoutAnchorablePaneGroup>
                            </avalonDock:LayoutPanel>
                        </avalonDock:LayoutRoot>
                    </avalonDock:DockingManager>
                </Grid>
                
                <!-- Bottom Panel: Output Log -->
                <Border Grid.Row="2" Background="{StaticResource BgCardBrush}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderSubtleBrush}" MaxHeight="150">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="OUTPUT" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Height="60" Background="{StaticResource BgDeepBrush}">
                            <TextBox x:Name="OutputLog" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource MonoFont}" FontSize="10" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0" Padding="8,4" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Text="; E3Studio initialized&#x0a;; Ready"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- ═══════════════════════════════════════════════════════════════════
                 STATUS BAR
                 ═══════════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource BgCardBrush}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderSubtleBrush}" CornerRadius="0,0,8,8" Padding="12,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentSuccessBrush}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Units: mm" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,16,0"/>
                        <TextBlock x:Name="StatusGridText" Text="Grid: 10mm" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,0,16,0"/>
                        <TextBlock x:Name="StatusZoomText" Text="Zoom: 100%" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
