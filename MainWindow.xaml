<Window x:Class="E3Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:local="clr-namespace:E3Studio.Models"
        mc:Ignorable="d"
        Title="E3Studio CAM"
        Height="950" Width="1600"
        MinHeight="700" MinWidth="1100"
        Background="{StaticResource BgDeepBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyCommand}"/>
        <KeyBinding Key="X" Modifiers="Control" Command="{Binding CutCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}"/>
    </Window.InputBindings>
    
    <Window.Resources>
        <ContextMenu x:Key="NodeContextMenu">
            <MenuItem Header="Copy" Click="CopyNode_Click"/>
            <MenuItem Header="Cut" Click="CutNode_Click"/>
            <MenuItem Header="Duplicate" Click="DuplicateNode_Click"/>
            <Separator/>
            <MenuItem Header="Delete" Click="DeleteNode_Click" Foreground="#FF6B6B"/>
        </ContextMenu>
        
        <!-- Fusion 360 Style Icon Button -->
        <Style x:Key="RailButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A35"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#35354A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Rail Toggle Button -->
        <Style x:Key="RailToggleButton" TargetType="RadioButton">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A35"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#00D4AA20"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Toolbar Button -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource BgActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Toolbar Toggle -->
        <Style x:Key="ToolbarToggle" TargetType="RadioButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#0D0D0F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Action Button (Primary) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0D0D0F"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20E8BC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00AA88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      CornerRadius="8" 
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    
    <Border Background="{StaticResource BgBaseBrush}" 
            BorderBrush="{StaticResource BorderSubtleBrush}" 
            BorderThickness="1" 
            CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            
            <!-- ═══════════════════════════════════════════════════════════════════
                 TITLE BAR (Top)
                 ═══════════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource BgCardBrush}" CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <Border Width="24" Height="24" CornerRadius="5" Background="{StaticResource AccentGradient}" Margin="0,0,12,0">
                            <TextBlock Text="E3" FontWeight="Bold" FontSize="10" Foreground="#0D0D0F" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="E3Studio" Style="{StaticResource TextBase}" FontWeight="SemiBold" 
                                   VerticalAlignment="Center" FontSize="14"/>
                        <TextBlock Text=" — " Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock x:Name="TitleProjectName" Text="CAM Workspace" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource BtnIcon}" Width="46" Height="40" Click="BtnMinimize_Click" ToolTip="Minimize">
                            <Path Data="M5,12 L19,12" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.2"/>
                        </Button>
                        <Button Style="{StaticResource BtnIcon}" Width="46" Height="40" Click="BtnMaximize_Click" ToolTip="Maximize">
                            <Path Data="M5,5 L19,5 L19,19 L5,19 Z" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.2" Fill="Transparent"/>
                        </Button>
                        <Button Width="46" Height="40" Click="BtnClose_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" ToolTip="Close">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="Transparent" CornerRadius="0,8,0,0">
                                                    <Path x:Name="icon" Data="M7,7 L17,17 M17,7 L7,17" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.2"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentDangerBrush}"/>
                                                        <Setter TargetName="icon" Property="Stroke" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- ═══════════════════════════════════════════════════════════════════
                 LEFT RAIL (Fusion 360 Style)
                 ═══════════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource BgCardBrush}" 
                    BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderSubtleBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Navigation Section -->
                        <Border Padding="0,12,0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                            <StackPanel>
                                <Button x:Name="RailHomeBtn" Style="{StaticResource RailButton}" 
                                        ToolTip="Home" Click="RailHome_Click">
                                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                                <Button x:Name="RailDesignBtn" Style="{StaticResource RailButton}"
                                        ToolTip="Design" Click="RailDesign_Click">
                                    <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65,21.1,6,20.71,5.61L18.39,3.29C18,2.9,17.35,2.9,16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                                <Button x:Name="RailCAMBtn" Style="{StaticResource RailButton}"
                                        ToolTip="CAM" Click="RailCAM_Click">
                                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        
                        <!-- Tools Section -->
                        <Border Padding="0,12,0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                            <StackPanel>
                                <Button Style="{StaticResource RailButton}" ToolTip="New Project (Ctrl+N)" Click="NewProject_Click">
                                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                                <Button Style="{StaticResource RailButton}" ToolTip="Open Project (Ctrl+O)" Click="OpenProject_Click">
                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                                <Button Style="{StaticResource RailButton}" ToolTip="Save (Ctrl+S)" Click="SaveProject_Click">
                                    <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        
                        <!-- Import Section -->
                        <Border Padding="0,12,0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                            <StackPanel>
                                <Button x:Name="ImportBtn" Style="{StaticResource RailButton}" ToolTip="Import" Click="ImportBtn_Click">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Import DXF/SVG" Click="ImportDXF_Click"/>
                                            <MenuItem Header="Import STL (3D Model)" Click="ImportSTL_Click"/>
                                            <MenuItem Header="Import STEP/IGES" Click="ImportSTEP_Click"/>
                                            <MenuItem Header="Import 3MF" Click="Import3MF_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Import Gerber (PCB)" Click="ImportGerber_Click"/>
                                            <MenuItem Header="Import PDF (Vector)" Click="ImportPDF_Click"/>
                                            <MenuItem Header="Import G-Code (Backplot)" Click="ImportGCode_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Path Data="M14,13V17H10V13H7L12,8L17,13M12,3C14.76,3 17.1,4.78 17.84,7.16C18.22,7.53 18.46,8.07 18.46,8.64C18.46,9.21 18.22,9.75 17.84,10.12L12,16L6.16,10.12C5.78,9.75 5.54,9.21 5.54,8.64C5.54,8.07 5.78,7.53 6.16,7.16C6.9,4.78 9.24,3 12,3Z" 
                                          Fill="{StaticResource AccentBrush}" Width="20" Height="20"/>
                                </Button>
                                <Button Style="{StaticResource RailButton}" ToolTip="Export G-Code" Click="ExportGCode_Click">
                                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12,11L9,14H11V18H13V14H15L12,11Z" 
                                          Fill="{StaticResource TextSecondaryBrush}" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        
                        <!-- View Section -->
                        <Border Padding="0,12,0,8">
                            <StackPanel>
                                <RadioButton x:Name="View2DBtn" GroupName="ViewMode" Style="{StaticResource RailToggleButton}" 
                                             IsChecked="True" Checked="View2D_Checked" ToolTip="2D View">
                                    <TextBlock Text="2D" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </RadioButton>
                                <RadioButton x:Name="View3DBtn" GroupName="ViewMode" Style="{StaticResource RailToggleButton}" 
                                             Checked="View3D_Checked" ToolTip="3D View">
                                    <TextBlock Text="3D" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </RadioButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- ═══════════════════════════════════════════════════════════════════
                 MAIN CONTENT
                 ═══════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- ═══ CONTEXT TOOLBAR ═══ -->
                <Border Grid.Row="0" Background="{StaticResource BgCardBrush}" Padding="12,6"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderSubtleBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left: Context Tools -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Select" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" 
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <RadioButton GroupName="Tools" Click="Tool_Click" Tag="Select" Style="{StaticResource ToolbarToggle}" IsChecked="True" ToolTip="Select (S)">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M4,4 L12,20 L15,14 L21,20 L23,18 L17,12 L23,10 L4,4" Fill="{StaticResource TextBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Select" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Tools" Click="Tool_Click" Tag="Move" Style="{StaticResource ToolbarToggle}" ToolTip="Move (M)">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,4 L15,8 H13 V11 H16 V9 L20,12 L16,15 V13 H13 V16 H15 L12,20 L9,16 H11 V13 H8 V15 L4,12 L8,9 V11 H11 V8 H9 L12,4" Fill="{StaticResource TextSecondaryBrush}" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Move" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            
                            <Border Width="1" Background="{StaticResource BorderSubtleBrush}" Margin="12,4"/>
                            
                            <!-- CAM Operations -->
                            <TextBlock Text="CAM" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" 
                                       FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <Button Style="{StaticResource ToolbarButton}" Click="CreateProfileToolpath_Click" ToolTip="Profile Toolpath">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M4,4 L20,4 L20,20 L4,20 Z" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.5" Fill="Transparent" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Profile" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Click="CreatePocketToolpath_Click" ToolTip="Pocket Toolpath">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="14" Height="14" Margin="0,0,6,0">
                                        <Path Data="M2,2 L14,2 L14,14 L2,14 Z" Stroke="{StaticResource AccentSecondaryBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                        <Path Data="M4,5 L12,5 M4,8 L12,8 M4,11 L12,11" Stroke="{StaticResource AccentSecondaryBrush}" StrokeThickness="0.7"/>
                                    </Grid>
                                    <TextBlock Text="Pocket" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Click="CreateDrillToolpath_Click" ToolTip="Drill Toolpath">
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="14" Height="14" Margin="0,0,6,0">
                                        <Ellipse Width="12" Height="12" Stroke="{StaticResource AccentWarningBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="3" Height="3" Fill="{StaticResource AccentWarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="Drill" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Border Width="1" Background="{StaticResource BorderSubtleBrush}" Margin="12,4"/>
                            
                            <!-- Tool Selection -->
                            <TextBlock Text="Tool:" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" 
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="QuickToolCombo" Width="160" Height="28" VerticalAlignment="Center"
                                      SelectionChanged="QuickToolCombo_Changed" FontSize="11">
                                <ComboBoxItem Content="T1: Ø6mm End Mill" Tag="6;Endmill;1" IsSelected="True"/>
                                <ComboBoxItem Content="T2: Ø3.175mm End Mill" Tag="3.175;Endmill;2"/>
                                <ComboBoxItem Content="T3: Ø3mm End Mill" Tag="3;Endmill;3"/>
                                <ComboBoxItem Content="T4: Ø6mm Ball Nose" Tag="6;BallNose;4"/>
                                <ComboBoxItem Content="T5: Ø3mm Ball Nose" Tag="3;BallNose;5"/>
                                <ComboBoxItem Content="T6: 60° V-Bit" Tag="60;VBit;6"/>
                                <ComboBoxItem Content="T7: 90° V-Bit" Tag="90;VBit;7"/>
                                <ComboBoxItem Content="T8: Ø3mm Drill" Tag="3;Drill;8"/>
                                <ComboBoxItem Content="T9: Ø6mm Drill" Tag="6;Drill;9"/>
                                <Separator/>
                                <ComboBoxItem Content="Manage Tools..." Tag="manage"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <!-- Right: Action Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="SIMULATE" Style="{StaticResource ToolbarButton}" Click="SimulateAll_Click" 
                                    ToolTip="Simulate Toolpaths" Margin="0,0,8,0"/>
                            <Button Content="GENERATE" Style="{StaticResource ActionButton}" Click="GenerateGCode_Click" 
                                    ToolTip="Generate G-Code"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- ═══ VIEWPORT & PANELS ═══ -->
                <Grid Grid.Row="1">
                    <!-- Welcome Screen -->
                    <Grid x:Name="WelcomeScreen" Panel.ZIndex="10" Background="{StaticResource BgDeepBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="580" Margin="0,40,0,40">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                                    <Border Width="72" Height="72" CornerRadius="16" Background="{StaticResource AccentGradient}" Margin="0,0,20,0">
                                        <TextBlock Text="E3" FontWeight="Bold" FontSize="30" Foreground="#0D0D0F" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="E3Studio" FontSize="38" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="Professional CNC CAM Software" FontSize="14" 
                                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="2,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,36"/>
                                
                                <TextBlock Text="GET STARTED" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12"/>
